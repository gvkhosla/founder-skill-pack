{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://fskills.xyz/schemas/company-state.schema.json",
  "title": "CompanyState",
  "type": "object",
  "required": ["company", "metrics", "execution", "focus", "stateMeta"],
  "properties": {
    "company": {
      "type": "object",
      "required": ["name", "stage", "currentBottleneck"],
      "properties": {
        "name": { "type": "string" },
        "stage": {
          "type": "string",
          "enum": ["idea", "validating", "building", "launched", "revenue", "growing"]
        },
        "businessModel": { "type": "string" },
        "founderType": { "type": "string" },
        "teamShape": { "type": "string" },
        "currentBottleneck": { "type": "string" }
      },
      "additionalProperties": true
    },
    "founders": {
      "type": "object",
      "properties": {
        "primaryFounderMode": { "type": "string" },
        "riskTolerance": { "type": "string" },
        "timeHorizon": { "type": "string" },
        "keyConstraints": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": true
    },
    "product": {
      "type": "object",
      "additionalProperties": true
    },
    "goToMarket": {
      "type": "object",
      "additionalProperties": true
    },
    "metrics": {
      "type": "object",
      "properties": {
        "northStar": {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "value": { "type": "number" },
            "trend": { "type": "string" }
          },
          "additionalProperties": true
        },
        "pmfSignal": { "type": "string" },
        "revenueMrr": { "type": "number" },
        "pipelineHealth": { "type": "string" },
        "activationHealth": { "type": "string" },
        "retentionHealth": { "type": "string" },
        "cacHealth": { "type": "string" }
      },
      "additionalProperties": true
    },
    "execution": {
      "type": "object",
      "properties": {
        "implementationConfidence": { "type": "string" },
        "architectureConfidence": { "type": "string" },
        "qaConfidence": { "type": "string" },
        "reviewState": { "type": "string" },
        "designToCodeReady": { "type": "boolean" },
        "releaseReadiness": { "type": "string" }
      },
      "additionalProperties": true
    },
    "support": {
      "type": "object",
      "properties": {
        "topTicketThemes": {
          "type": "array",
          "items": { "type": "string" }
        },
        "onboardingFrictionKnown": { "type": "boolean" },
        "churnThemeKnown": { "type": "boolean" }
      },
      "additionalProperties": true
    },
    "hiring": {
      "type": "object",
      "properties": {
        "nextHireNeeded": { "type": "string" },
        "capacityPressure": { "type": "string" }
      },
      "additionalProperties": true
    },
    "focus": {
      "type": "object",
      "properties": {
        "thisWeek": { "type": "string" },
        "activeSequence": { "type": "string" },
        "activeExperiments": {
          "type": "array",
          "items": { "type": "string" }
        },
        "openQuestions": {
          "type": "array",
          "items": { "type": "string" }
        },
        "recommendedNext": {
          "type": "object",
          "properties": {
            "type": { "type": "string" },
            "name": { "type": "string" },
            "reason": { "type": "string" }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "stateMeta": {
      "type": "object",
      "required": ["version", "lastUpdated"],
      "properties": {
        "version": { "type": "number" },
        "lastUpdated": { "type": "string" },
        "lastReviewed": { "type": "string" },
        "confidence": { "type": "string" }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
